@HostAddress = http://localhost:5048
@BeatmapHash = 473eae3bc04005fc728876b096c29fb1f5f74087046ebb2945e08612ec7c798b
@BeatmapMd5Hash = 7b143bd479e4284d1b219afd6e69615d

GET {{HostAddress}}/api/status
Accept: application/json

### Lazer: query scores
GET {{HostAddress}}/api/lazer/scores?rql=BeatmapHash=="{{BeatmapHash}}"&depth=1
Accept: application/json

### Lazer: query beatmaps
GET {{HostAddress}}/api/lazer/beatmaps?rql=Hash=="{{BeatmapHash}}"&depth=1
Accept: application/json

### Lazer: query beatmaps by BeatmapSet OnlineID
GET {{HostAddress}}/api/lazer/beatmaps?rql=BeatmapSet.OnlineID==2280130
Accept: application/json

### Lazer: query beatmap sets
GET {{HostAddress}}/api/lazer/beatmapsets?rql=OnlineID==2280130&depth=1
Accept: application/json

### Lazer: query collections
GET {{HostAddress}}/api/lazer/collections?rql=Name=="love"&depth=1
Accept: application/json

### Lazer: get file by hash
GET {{HostAddress}}/api/lazer/files/{{BeatmapHash}}
Accept: application/octet-stream

### Stable: get file with exact path
GET {{HostAddress}}/api/stable/files/Data/r/{{BeatmapMd5Hash}}-134239924909535197.osr
Accept: application/octet-stream

### Stable: get file with wildcard
GET {{HostAddress}}/api/stable/files/Data/r/{{BeatmapMd5Hash}}-*.osr
Accept: application/octet-stream

### Stable: create collection
POST {{HostAddress}}/api/stable/collections
Content-Type: application/json

{
  "name": "Test",
  "beatmapMd5Hashes": ["{{BeatmapMd5Hash}}"]
}

### Lazer: create collection
POST {{HostAddress}}/api/lazer/collections
Content-Type: application/json

{
  "name": "Test",
  "beatmapMd5Hashes": ["{{BeatmapMd5Hash}}"]
}

### APIv2: proxy - get beatmap by ID (requires configured credentials)
GET {{HostAddress}}/api/osuapi/v2/beatmaps/5288868
Accept: application/json

### APIv2: proxy - get user by ID
GET {{HostAddress}}/api/osuapi/v2/users/95915
Accept: application/json

### APIv2: proxy - download replay (requires configured credentials)
GET {{HostAddress}}/api/osuapi/v2/scores/mania/635785967/download
Accept: application/octet-stream

### APIv2: proxy - get rankings (requires configured credentials)
GET {{HostAddress}}/api/osuapi/v2/rankings/osu/performance?page=1
Accept: application/json
