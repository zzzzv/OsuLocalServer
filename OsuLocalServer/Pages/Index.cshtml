@page
@model IndexModel
@{
    ViewData["Title"] = "状态";
}
<div style="padding:20px; max-width:600px; margin:0 auto; line-height:2">
    <h1>OsuLocalServer</h1>
    <p>版本: @Model.Version
    <span id="version-check"><span style="color:var(--muted)">⏳ 检查更新中...</span></span>
    </p>

    <h2>Stable</h2>
    <p>路径: @Model.Settings.Stable.OsuRootPath<br>
    可用: @(Model.Settings.Stable.IsAvailable ? "✅" : "❌")</p>

    <h2>Lazer</h2>
    <p>路径: @Model.Settings.Lazer.ClientRealmPath<br>
    可用: @(Model.Settings.Lazer.IsAvailable ? "✅" : "❌")</p>

    <h2>API v2</h2>
    <p>已配置: @(Model.ApiV2Configured ? "✅" : "❌")<br>
    令牌有效: @(Model.ApiV2TokenValid ? "✅" : "❌")</p>

    <h2>Mania Lab</h2>
    <p>
      版本: <span id="mania-lab-version">@(Model.ManiaLabState.InstalledVersion ?? "未安装")</span>
      <span id="mania-lab-status"></span>
      <span id="mania-lab-progress" style="display:none;color:var(--running)"></span>
    </p>
    <p>
      <a href="@Model.ManiaLabUrl" target="_blank" id="mania-lab-link"
         style="display:@(Model.ManiaLabState.IsAvailable ? "inline" : "none")">
        🔗 新窗口打开
      </a>
    </p>
</div>

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
<script>
function updateVersionCheck(result) {
  var el = document.getElementById("version-check");
  if (!el) return;
  if (result.isNewer) {
    el.innerHTML = '<br><a href="@Model.LatestReleaseUrl" target="_blank">📥 新版本 ' + result.latestVersion + ' 可用</a>';
  } else if (result.isUpToDate) {
    el.innerHTML = '<br><span style="color:green">✅ 已是最新版本</span>';
  } else if (result.isNewer === false && result.isUpToDate === false) {
    el.innerHTML = '<br><span style="color:var(--muted)">⚠ 检查更新失败</span>';
  }
}

@if (Model.VersionCheck is not null)
{
  <text>updateVersionCheck(@Json.Serialize(Model.VersionCheck));</text>
}

const connection = new signalR.HubConnectionBuilder()
  .withUrl('@ServerHub.Path')
  .withAutomaticReconnect()
  .build();

connection.on("VersionCheckResult", updateVersionCheck);

// ManiaLab events
function updateManiaLab(result) {
  var el = document.getElementById("mania-lab-version");
  if (el && result.latestVersion) {
    el.textContent = result.latestVersion;
  }
  var status = document.getElementById("mania-lab-status");
  if (status) {
    if (result.error) {
      status.innerHTML = '<span style="color:var(--error)">⚠ ' + result.error + '</span>';
    } else {
      status.innerHTML = '<span style="color:var(--muted)">✅ 已是最新</span>';
    }
  }
}

connection.on("ManiaLabVersionResult", updateManiaLab);
connection.on("ManiaLabVersionFailed", function(source, reason) {
  var status = document.getElementById("mania-lab-status");
  if (status) status.innerHTML = '<span style="color:var(--error)">⚠ ' + source + ': ' + reason + '</span>';
});
connection.on("ManiaLabDownloadProgress", function(msg) {
  var el = document.getElementById("mania-lab-progress");
  if (el) { el.style.display = "inline"; el.textContent = "⏳ " + msg; }
  var status = document.getElementById("mania-lab-status");
  if (status) status.innerHTML = '';
});
connection.on("ManiaLabDownloadComplete", function(version) {
  var el = document.getElementById("mania-lab-progress");
  if (el) { el.style.display = "none"; }
  var v = document.getElementById("mania-lab-version");
  if (v) v.textContent = version;
  var link = document.getElementById("mania-lab-link");
  if (link) link.style.display = "inline";
  var status = document.getElementById("mania-lab-status");
  if (status) status.innerHTML = '<span style="color:green">✅ 下载完成</span>';
});
connection.on("ManiaLabDownloadFailed", function(version, reason) {
  var el = document.getElementById("mania-lab-progress");
  if (el) { el.style.display = "none"; el.textContent = ''; }
  var status = document.getElementById("mania-lab-status");
  if (status) status.innerHTML = '<span style="color:var(--error)">⚠ 下载失败: ' + reason + '</span>';
});
connection.on("VersionCheckFailed", function(source, reason) {
  var el = document.getElementById("version-check");
  if (el) el.innerHTML = '<br><span style="color:var(--muted)">⚠ ' + source + ': ' + reason + '</span>';
});
connection.start().catch(function() {});
</script>
}
