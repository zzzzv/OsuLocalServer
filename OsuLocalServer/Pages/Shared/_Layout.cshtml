<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>@ViewData["Title"] — OsuLocalServer</title>
<style>
  :root {
    --accent: #4a7dff;
    --text: #1a1a2e;
    --muted: #888;
    --border: #e0e0e0;
    --bg: #f8f9fa;
    --card-bg: #fff;
    --success: #2ecc71;
    --error: #e74c3c;
    --warn: #f39c12;
    --running: #3498db;
    --font-mono: 'Cascadia Code', 'JetBrains Mono', 'Consolas', monospace;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    background: var(--bg); color: var(--text); min-height: 100vh;
  }
  a { color: inherit; text-decoration: none; }

  /* Navbar */
  .navbar {
    display: flex; align-items: center; justify-content: center; gap: 20px;
    padding: 0 24px; height: 48px;
    background: var(--card-bg);
    border-bottom: 1px solid var(--border);
    font-size: 0.88rem;
  }
  .navbar .brand {
    font-weight: 600; font-size: 0.95rem;
    margin-right: 8px;
  }
  .navbar a {
    padding: 4px 8px; border-radius: 4px;
    transition: background .15s;
  }
  .navbar a:hover { background: #f0f4ff; }
  .navbar a.active {
    background: var(--accent); color: #fff;
  }
  .navbar .github-link {
    display: flex; align-items: center;
    padding: 6px; border-radius: 6px;
  }
  .navbar .github-link:hover { background: #f0f4ff; }
  .navbar .github-link svg {
    display: block; width: 22px; height: 22px;
  }

</style>
  @await RenderSectionAsync("Head", required: false)
</head>
<body>
  <nav class="navbar">
    <span class="brand">OsuLocalServer</span>
    <a asp-page="/Index" class="@(ViewContext.RouteData.Values["page"] as string == "/Index" ? "active" : "")">状态</a>
    <a asp-page="/Settings" class="@(ViewContext.RouteData.Values["page"] as string == "/Settings" ? "active" : "")">设置</a>
    <a asp-page="/Management" class="@(ViewContext.RouteData.Values["page"] as string == "/Management" ? "active" : "")">管理</a>
    <a href="https://github.com/zzzzv/OsuLocalServer" target="_blank" class="github-link" title="GitHub 仓库">
      <svg viewBox="0 0 16 16" fill="currentColor">
        <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
      </svg>
    </a>
  </nav>
  <main>
    @RenderBody()
  </main>
  @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
