@page
@model SettingsModel
@{
    ViewData["Title"] = "设置";
}
@section Head {
<style>
  .page-wrap {
    display: flex; align-items: center; justify-content: center;
    padding: 40px 20px; min-height: calc(100vh - 48px);
  }
  .container { max-width: 520px; width: 100%; }
  h1 { font-size: 1.3rem; font-weight: 600; margin-bottom: 2px; }
  .subtitle { color: var(--muted); font-size: 0.82rem; margin-bottom: 20px; }
  .card {
    background: var(--card-bg); border-radius: 10px; padding: 24px 28px;
    box-shadow: 0 1px 4px rgba(0,0,0,.08);
  }
  .section { margin-bottom: 20px; }
  .section:last-child { margin-bottom: 0; }
  .section-title {
    font-size: 0.78rem; font-weight: 600; text-transform: uppercase;
    letter-spacing: .04em; color: var(--muted); margin-bottom: 10px;
    padding-bottom: 6px; border-bottom: 1px solid var(--border);
  }
  .form-group { margin-bottom: 12px; }
  .form-group:last-child { margin-bottom: 0; }
  label { display: block; font-size: 0.8rem; color: var(--muted); margin-bottom: 3px; }
  input[type="text"], input[type="password"] {
    width: 100%; padding: 9px 11px; border: 1px solid var(--border); border-radius: 6px;
    background: var(--card-bg); color: var(--text); font-size: 0.88rem;
    outline: none;
  }
  input:focus { border-color: var(--accent); box-shadow: 0 0 0 3px rgba(74,125,255,.1); }
  .hint { font-size: 0.72rem; color: var(--muted); margin-top: 3px; }
  .status-bar {
    display: flex; align-items: center; gap: 8px; padding: 10px 14px;
    border-radius: 6px; margin-bottom: 16px; font-size: 0.84rem;
    border: 1px solid var(--border);
  }
  .status-bar.ok { background: #f0faf0; border-color: #c8e6c9; color: #2e7d32; }
  .status-bar.fail { background: #fff5f5; border-color: #ffcdd2; color: #c62828; }
  .status-dot {
    width: 8px; height: 8px; border-radius: 50%; display: inline-block; flex-shrink: 0;
  }
  .status-dot.ok { background: var(--success); }
  .status-dot.fail { background: var(--error); }
  .header-row {
    display: flex; align-items: center; justify-content: space-between; gap: 10px;
  }
  .btn-icon {
    padding: 4px 10px; border: 1px solid var(--border); border-radius: 5px;
    background: var(--card-bg); color: var(--text); font-size: 0.78rem;
    cursor: pointer; white-space: nowrap; transition: background .15s;
  }
  .btn-icon:hover { background: #f0f4ff; }
  .btn-save {
    width: 100%; padding: 10px; border: none; border-radius: 6px;
    background: var(--accent); color: #fff; font-size: 0.88rem;
    cursor: pointer; transition: background .2s; font-weight: 500;
  }
  .btn-save:hover { background: #3a6ae8; }
  .alert {
    padding: 10px 14px; border-radius: 6px; margin-bottom: 16px; font-size: 0.82rem;
  }
  .alert.success { background: #f0faf0; color: #2e7d32; border: 1px solid #c8e6c9; }
  .alert.error { background: #fff5f5; color: #c62828; border: 1px solid #ffcdd2; }
</style>
}
<div class="page-wrap">
  <div class="container">
    <div class="header-row">
      <div>
        <h1>设置</h1>
        <p class="subtitle">OsuLocalServer 配置</p>
      </div>
      <form method="post" asp-page-handler="openfolder">
        <button type="submit" class="btn-icon">📂 数据文件夹</button>
      </form>
    </div>

    <div class="card">
      @if (Model.IsConfigured && Model.TokenValid)
      {
        <div class="status-bar ok"><span class="status-dot ok"></span>API v2 已配置 · Token 有效</div>
      }
      else if (Model.IsConfigured)
      {
        <div class="status-bar ok"><span class="status-dot ok"></span>API v2 已配置 · Token 待获取</div>
      }
      else
      {
        <div class="status-bar fail"><span class="status-dot fail"></span>API v2 未配置</div>
      }

      @if (!string.IsNullOrEmpty(Model.Message))
      {
        <div class="alert @(Model.MessageType)">@Model.Message</div>
      }

      <form method="post">
        <div class="section">
          <div class="section-title">服务器</div>
          <div class="form-group">
            <label for="urls">监听地址</label>
            <input type="text" id="urls" name="urls" value="@Model.Urls" autocomplete="off">
          </div>
          <div class="form-group">
            <label>
              <input type="checkbox" name="openBrowserOnStartup" value="true" checked="@Model.OpenBrowserOnStartup">
              启动时打开浏览器
            </label>
          </div>
          <div class="form-group">
            <label>
              <input type="checkbox" name="backupBeforeWrite" value="true" checked="@Model.BackupBeforeWrite">
              写入数据库前备份
            </label>
          </div>
        </div>

        <div class="section">
          <div class="section-title">Lazer</div>
          <div class="form-group">
            <label for="clientRealmPath">Client Realm 路径</label>
            <input type="text" id="clientRealmPath" name="clientRealmPath" value="@Model.ClientRealmPath" autocomplete="off">
            <div class="hint">指向 osu! 数据目录下的 client.realm 文件</div>
          </div>
        </div>

        <div class="section">
          <div class="section-title">Stable</div>
          <div class="form-group">
            <label for="osuRootPath">osu! 安装目录</label>
            <input type="text" id="osuRootPath" name="osuRootPath" value="@Model.OsuRootPath" autocomplete="off">
            <div class="hint">包含 osu!.exe 的目录</div>
          </div>
        </div>

        <div class="section">
          <div class="section-title">API v2</div>
          <div class="form-group">
            <label for="clientId">Client ID</label>
            <input type="text" id="clientId" name="clientId" value="@Model.ClientId" autocomplete="off">
          </div>
          <div class="form-group">
            <label for="clientSecret">Client Secret</label>
            <input type="password" id="clientSecret" name="clientSecret" placeholder="输入新值以覆盖" autocomplete="off">
          </div>
        </div>

        <button type="submit" class="btn-save" id="saveBtn">保存设置</button>
      </form>
    </div>
  </div>
</div>
